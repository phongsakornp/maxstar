MAXSTAR_HOST=your_node_ip_or_hostname
MAXSTAR_PORT=4569
MAXSTAR_USER=your_iax2_username
MAXSTAR_SECRET=your_secret_here
MAXSTAR_NODE=your_node_number
MAXSTAR_CONTEXT=iax-client
# Optional -- used only by the link-history screen ('h') to SSH into the
# node's own Pi and read/prune pi_logger/node_link_logger.py's log.
# Left blank, these default to "asl" and "maxstar-logger" respectively.
MAXSTAR_SSH_USER=asl
MAXSTAR_SSH_LOGGER_DIR=maxstar-logger
